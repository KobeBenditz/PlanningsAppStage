@*
    Views/Account/Login.cshtml
    ==========================

    Dummy loginpagina.
    Nog GEEN echte loginlogica.
    Enkel om navigatie en layout te testen.
*@
@{
    ViewData["Title"] = "Login";
}

<h1>Login</h1>

@*
    Dummy formulier
    Dit formulier doet voorlopig niets
*@
<form>

    <div>
        <label for="email">E-mail</label><br />
        <input type="email" id="email" name="email" />
    </div>

    <br />

    <div>
        <label for="password">Wachtwoord</label><br />
        <input type="password" id="password" name="password" />
    </div>

    <br />

    <button type="submit">
        Inloggen
    </button>

</form>

<p>
    Dit is voorlopig een dummy login.
    Er wordt nog niets gecontroleerd.
</p>
