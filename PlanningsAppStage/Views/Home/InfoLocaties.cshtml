@model List<PlanningsAppStage.Models.Locatie>

@{
    ViewData["Title"] = "Info locaties";
}

<h2>Locatie toevoegen</h2>

<form method="post">

    <!-- BASISGEGEVENS LOCATIE -->
    <div class="row mb-3">
        <div class="col-md-3">
            <label class="form-label">Naam</label>
            <input type="text" class="form-control" name="Naam" />
        </div>

        <div class="col-md-3">
            <label class="form-label">Straat</label>
            <input type="text" class="form-control" name="Straat" />
        </div>

        <div class="col-md-1">
            <label class="form-label">Nr</label>
            <input type="text" class="form-control" name="Nummer" />
        </div>

        <div class="col-md-2">
            <label class="form-label">Gemeente</label>
            <input type="text" class="form-control" name="Gemeente" />
        </div>

        <div class="col-md-1">
            <label class="form-label">Postcode</label>
            <input type="text" class="form-control" name="Postcode" />
        </div>
    </div>

    <!-- AANTAL SOORTEN -->
    <div class="row mb-3">
        <div class="col-md-2">
            <label class="form-label">Aantal soorten</label>
            <input type="number"
                   id="aantalSoorten"
                   class="form-control"
                   value="1"
                   min="1" />
        </div>
    </div>

    <!-- DYNAMISCHE SOORTEN -->
    <div id="soortenContainer"></div>

    <button type="submit" class="btn btn-primary mt-3">
        Toevoegen
    </button>
</form>

<hr />

<h2>Overzicht locaties</h2>
<table class="table table-bordered">
    <thead>
        <tr>
            
            <th>
                Naam
                <span class="th-buttons">
                    <button class="sort-btn" title="Sorteren">▲</button>
                    <button class="filter-btn" title="Filteren">🔍</button>
                </span>
            </th>
            <th>
                Adres
                <span class="th-buttons">
                    <button class="sort-btn" title="Sorteren">▲</button>
                    <button class="filter-btn" title="Filteren">🔍</button>
                </span>
            </th>

            <th style="width:40px;"></th> @* actie-kolom *@
        </tr>
    </thead>
    <tbody>
        @foreach (var locatie in Model)
        {
            <tr>
                <td>@locatie.Naam</td>
                <td>@locatie.Adres</td>
                <td class="text-center">
                    <button type="button"
                            class="btn btn-sm btn-outline-secondary"
                            data-bs-toggle="modal"
                            data-bs-target="#locatieModal"
                            data-naam="@locatie.Naam"
                            data-adres="@locatie.Adres"
                            data-soorten='@Html.Raw(
                                                                    System.Text.Json.JsonSerializer.Serialize(locatie.Soorten)
                                                                )'>
                        ℹ
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="modal fade" id="locatieModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="locatieModalTitel"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p id="locatieAdres"></p>

                <h6>Soorten & uren</h6>
                <ul id="locatieSoorten"></ul>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener("DOMContentLoaded", function () {

    // =====================================
    // 1️⃣ MODAL: locatie‑info vullen
    // =====================================
    const modal = document.getElementById("locatieModal");

    if (modal) {
        modal.addEventListener("show.bs.modal", function (event) {

            const button = event.relatedTarget;
            if (!button) return;

            const naam = button.dataset.naam;
            const adres = button.dataset.adres;
            const soorten = JSON.parse(button.dataset.soorten || "[]");

            document.getElementById("locatieModalTitel").textContent = naam;
            document.getElementById("locatieAdres").textContent = adres;

            const lijst = document.getElementById("locatieSoorten");
            lijst.innerHTML = "";

            soorten.forEach(s => {
                const li = document.createElement("li");
                li.textContent = `${s.Soort}: ${s.StartUur} – ${s.EindUur}`;
                lijst.appendChild(li);
            });
        });
    }

    // =====================================
    // 2️⃣ FORMULIER: soorten dynamisch renderen
    // =====================================
    const aantalInput = document.getElementById("aantalSoorten");
    const container = document.getElementById("soortenContainer");

    if (!aantalInput || !container) {
        console.error("InfoLocaties: aantalSoorten of soortenContainer niet gevonden");
        return;
    }

    function renderSoorten() {
        container.innerHTML = "";
        const aantal = parseInt(aantalInput.value);

        for (let i = 0; i < aantal; i++) {

            const row = document.createElement("div");
            row.className = "row mb-3";

            row.innerHTML = `
                <div class="col-md-3">
                    <div class="position-relative soort-wrapper">
                        <label class="form-label">Soort</label>

                        <div class="form-control soortSelect" style="cursor:pointer;">
                            <span class="soortGeselecteerd">-- kies --</span>
                        </div>

                        <div class="border bg-white d-none position-absolute w-100 mt-1 soortDropdown"
                             style="z-index:1000;">
                            @foreach (string soort in ViewBag.Soorten)
                            {
                                <div class="soort-optie d-flex justify-content-between align-items-center"
                                     data-value="@soort">
                                    <span>@soort</span>
                                    <button type="button"
                                            class="btn btn-sm btn-link text-danger verwijder-soort"
                                            data-naam="@soort">✕</button>
                                </div>
                            }

                            <div class="border-top mt-1 pt-1 text-center">
                                <button type="button"
                                        class="btn btn-sm btn-outline-success voeg-soort-toe">
                                    + soort toevoegen
                                </button>
                            </div>
                        </div>

                        <input type="hidden"
                               name="Soorten[${i}].Soort"
                               class="soortValue" />
                    </div>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Startuur</label>
                    <input type="time"
                           class="form-control"
                           name="Soorten[${i}].StartUur" />
                </div>

                <div class="col-md-2">
                    <label class="form-label">Einduur</label>
                    <input type="time"
                           class="form-control"
                           name="Soorten[${i}].EindUur" />
                </div>
            `;

            container.appendChild(row);
        }
    }

    // 🔁 hertekenen bij wijziging
    aantalInput.addEventListener("change", renderSoorten);

    // ✅ initieel renderen
    renderSoorten();

});
</script>
}