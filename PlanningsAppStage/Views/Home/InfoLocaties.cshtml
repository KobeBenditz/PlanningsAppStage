@model List<PlanningsAppStage.Models.Locatie>

@{
    // Titel van de pagina
    ViewData["Title"] = "Info locaties";
}


<!-- ========================================= -->
<!-- BOVENSTE DEEL: LOCATIE TOEVOEGEN -->
<!-- ========================================= -->
<!--
    Dit formulier volgt de afbeelding:
    - meer invulvelden dan kolommen
    - invulbaar, maar doet voorlopig niets
-->

<h2>Locatie toevoegen</h2>



<form method="post">

    <!-- ========================= -->
    <!-- BASISGEGEVENS LOCATIE -->
    <!-- ========================= -->
    <div class="row mb-3">

        <div class="col-md-3">
            <label class="form-label">Naam</label>
            <input type="text"
                   class="form-control"
                   name="Naam" />
        </div>

        <div class="col-md-3">
            <label class="form-label">Straat</label>
            <input type="text"
                   class="form-control"
                   name="Straat" />
        </div>

        <div class="col-md-1">
            <label class="form-label">Nr</label>
            <input type="text"
                   class="form-control"
                   name="Nummer" />
        </div>

        <div class="col-md-2">
            <label class="form-label">Gemeente</label>
            <input type="text"
                   class="form-control"
                   name="Gemeente" />
        </div>

        <div class="col-md-1">
            <label class="form-label">Postcode</label>
            <input type="text"
                   class="form-control"
                   name="Postcode" />
        </div>

    </div>

    <!-- ========================= -->
    <!-- AANTAL SOORTEN -->
    <!-- ========================= -->
    <div class="row mb-3">
        <div class="col-md-2">
            <label class="form-label">Aantal soorten</label>
            <input type="number"
                   id="aantalSoorten"
                   class="form-control"
                   value="1"
                   min="1" />
        </div>
    </div>

    <!-- ========================= -->
    <!-- DYNAMISCHE SOORTEN -->
    <!-- ========================= -->
    <div id="soortenContainer"></div>

    <button type="submit" class="btn btn-primary mt-3">
        Toevoegen
    </button>

</form>




<hr />

<!-- ========================================= -->
<!-- TABEL: OVERZICHT LOCATIES -->
<!-- ========================================= -->

<h2>Overzicht locaties</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Naam</th>
            <th>Adres</th>
        </tr>
    </thead>
    <tbody>

        @*
            We overlopen de lijst van locaties
            Elke locatie wordt één rij in de tabel
        *@
        @foreach (var locatie in Model)
        {
            <tr>
                <td>@locatie.Naam</td>
                <td>@locatie.Adres</td>
            </tr>
        }

    </tbody>
</table>
@section Scripts {
    <script>
        const aantalInput = document.getElementById("aantalSoorten");
        const container = document.getElementById("soortenContainer");

        function renderSoorten() {

            // Alles leegmaken bij elke wijziging
            container.innerHTML = "";

            const aantal = parseInt(aantalInput.value);

            // Voor elk gekozen aantal bouwen we een rij
            for (let i = 0; i < aantal; i++) {

                const row = document.createElement("div");
                row.className = "row mb-3";

                row.innerHTML = `
                    <div class="col-md-2">
                        <label class="form-label">Soort</label>
                        <select class="form-control" name="Soorten[${i}].Soort">
                            <option value="Kamp">Kamp</option>
                            <option value="Event">Event</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">Startuur</label>
                        <input type="time"
                               class="form-control"
                               name="Soorten[${i}].StartUur" />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">Einduur</label>
                        <input type="time"
                               class="form-control"
                               name="Soorten[${i}].EindUur" />
                    </div>
                `;

                container.appendChild(row);
            }
        }

        // Hertekenen bij aanpassen van aantal
        aantalInput.addEventListener("change", renderSoorten);

        // Bij het laden van de pagina
        renderSoorten();
    </script>
}
``
