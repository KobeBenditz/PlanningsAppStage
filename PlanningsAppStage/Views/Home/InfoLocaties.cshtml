@model List<PlanningsAppStage.Models.Locatie>

@{
    // Titel van de pagina
    ViewData["Title"] = "Info locaties";
}

<!-- ========================================= -->
<!-- BOVENSTE DEEL: LOCATIE TOEVOEGEN -->
<!-- ========================================= -->
<!--
    Dit formulier volgt de afbeelding:
    - meer invulvelden dan kolommen
    - invulbaar, maar doet voorlopig niets
-->

<h2>Locatie toevoegen</h2>

<form method="post">
    <div class="row mb-3">

        <!-- Naam van de locatie -->
        <div class="col-md-3">
            <label class="form-label">Naam</label>
            <input type="text"
                   class="form-control"
                   name="Naam" />
        </div>

        <!-- Straat -->
        <div class="col-md-3">
            <label class="form-label">Straat</label>
            <input type="text"
                   class="form-control"
                   name="Straat" />
        </div>

        <!-- Nr -->
        <div class="col-md-1">
            <label class="form-label">Nr</label>
            <input type="text"
                   class="form-control"
                   name="Nummer" />
        </div>

        <!-- Gemeente -->
        <div class="col-md-2">
            <label class="form-label">Gemeente</label>
            <input type="text"
                   class="form-control"
                   name="Gemeente" />
        </div>

        <!-- Postcode -->
        <div class="col-md-1">
            <label class="form-label">Postcode</label>
            <input type="text"
                   class="form-control"
                   name="Postcode" />
        </div>

    </div>

    <button type="submit" class="btn btn-primary">
        Toevoegen
    </button>
</form>



<hr />

<!-- ========================================= -->
<!-- TABEL: OVERZICHT LOCATIES -->
<!-- ========================================= -->

<h2>Overzicht locaties</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Naam</th>
            <th>Adres</th>
        </tr>
    </thead>
    <tbody>

        @*
            We overlopen de lijst van locaties
            Elke locatie wordt één rij in de tabel
        *@
        @foreach (var locatie in Model)
        {
            <tr>
                <td>@locatie.Naam</td>
                <td>@locatie.Adres</td>
            </tr>
        }

    </tbody>
</table>
