@model List<PlanningsAppStage.Models.WorkshopInfo>

@{
    // Titel van de pagina
    ViewData["Title"] = "Info workshops";
}

<!-- ========================================= -->
<!-- BOVENSTE DEEL: WORKSHOP TOEVOEGEN -->
<!-- ========================================= -->
<!--
    Dit formulier is voorlopig alleen visueel.
    Alle velden zijn invulbaar, maar doen nog niets.
-->

<h2>Workshop toevoegen</h2>

<form method="post">
    <div class="row mb-3 align-items-end">

        <!-- Titel -->
        <div class="col-md-4">
            <label class="form-label">Titel</label>
            <input type="text"
                   class="form-control"
                   name="Titel" />
        </div>

        <!-- Soort -->
        <div class="col-md-2">
            <label class="form-label">Soort</label>
            <div class="position-relative">
                <label class="form-label">Soort</label>

                <!-- Fake select -->
                <div id="soortSelect" class="form-control" style="cursor:pointer;">
                    <span id="soortGeselecteerd">-- kies --</span>
                </div>

                <!-- Dropdown -->
                <div id="soortDropdown" class="border bg-white d-none position-absolute w-100 mt-1"
                     style="z-index:1000;">
                </div>

                <!-- Hidden echte waarde -->
                <input type="hidden" name="Soort" id="soortValue" />
            </div>
        </div>
        <!-- Aantal beschikbaar (kort input, volledig label) -->
        <div class="col-md-1">
            <label class="form-label">Aantal beschikbaar</label>
            <input type="number"
                   class="form-control"
                   name="AantalBeschikbaar"
                   min="0" />
        </div>

        <!-- Aantal dagen (kort input, volledig label) -->
        <div class="col-md-1">
            <label class="form-label">Aantal dagen</label>
            <input type="number"
                   class="form-control"
                   name="AantalDagen"
                   id="aantalDagenInput"
                   min="1" />
        </div>

        

        <!-- Verkorte versie -->
        
        <div class="row-md-3">
            <label class="form-label d-block">Verkorte versie mogelijk</label>

            <div class="verkorte-container">
                @for (int i = 1; i <= 10; i++)
                {
                    <label class="verkorte-vak">
                        <input type="checkbox"
                               name="VerkorteDagen"
                               value="@i"
                               data-dag="@i" />
                        <span>@i</span>
                    </label>
                }
            </div>
        </div>


    </div>

    <button type="submit" class="btn btn-success">
        Toevoegen
    </button>
</form>


<hr />

<!-- ========================================= -->
<!-- TABEL: OVERZICHT WORKSHOPS -->
<!-- ========================================= -->

<h2>Overzicht workshops</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th data-column="Titel">
                Titel
                <span class="th-buttons">
                    <button class="sort-btn" title="Sorteren">▲</button>
                    <button class="filter-btn" title="Filteren">🔍</button>
                </span>
            </th>
            <th data-column="Soort">
                Soort
                <span class="th-buttons">
                    <button class="sort-btn" title="Sorteren">▲</button>
                    <button class="filter-btn" title="Filteren">🔍</button>
                </span>
            </th>
            <th data-column="Aantal dagen">
                Aantal dagen
                <span class="th-buttons">
                    <button class="sort-btn" title="Sorteren">▲</button>
                    <button class="filter-btn" title="Filteren">🔍</button>
                </span>
            </th>
            <th data-column="Aantal beschikbaar">
                Aantal beschikbaar
                <span class="th-buttons">
                    <button class="sort-btn" title="Sorteren">▲</button>
                    <button class="filter-btn" title="Filteren">🔍</button>
                </span>
            </th>
        </tr>
    </thead>
    <tbody>

        @*
            We lopen door alle workshops uit de controller
            Elke workshop wordt één rij in de tabel
        *@
        @foreach (var workshop in Model)
        {
            <tr>
                <td>@workshop.Titel</td>
                <td>@workshop.Soort</td>
                <td>@workshop.AantalDagen</td>
                <td>@workshop.AantalBeschikbaar</td>
            </tr>
        }

    </tbody>
</table>
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {


            
        // ✅ DUMMY soorten (centrale waarheid)
            let soorten = [
                "Event",
                "Kamp",
                "Eventworkshop",
                "NS prikkeling",
                "NC verdieping",
                "Scholenworkshop",
                "Sluiting",
                "Werking",
                "Workshop"
            ];

            const select = document.getElementById("soortSelect");
            const dropdown = document.getElementById("soortDropdown");
            const label = document.getElementById("soortGeselecteerd");
            const hidden = document.getElementById("soortValue");

            function renderDropdown() {
                dropdown.innerHTML = "";

                soorten.forEach(soort => {
                    const div = document.createElement("div");
                    div.className = "soort-item";

                    div.innerHTML = `
                        <span>${soort}</span>
                        <span class="soort-remove">✕</span>
                    `;

                    // selecteren
                    div.children[0].onclick = () => {
                        label.textContent = soort;
                        hidden.value = soort;
                        dropdown.classList.add("d-none");
                    };

                    // verwijderen
                    div.children[1].onclick = (e) => {
                        e.stopPropagation();
                        if (confirm(`Soort "${soort}" verwijderen?`)) {
                            soorten = soorten.filter(s => s !== soort);
                            if (hidden.value === soort) {
                                hidden.value = "";
                                label.textContent = "-- kies --";
                            }
                            renderDropdown();
                        }
                    };

                    dropdown.appendChild(div);
                });

                // ➕ toevoegen
                const add = document.createElement("div");
                add.className = "soort-add";
                add.textContent = "+ soort toevoegen";
                add.onclick = () => {
                    const nieuw = prompt("Nieuwe soort naam:");
                    if (nieuw && !soorten.includes(nieuw)) {
                        soorten.push(nieuw);
                        renderDropdown();
                    }
                };

                dropdown.appendChild(add);
            }

            select.onclick = () => {
                dropdown.classList.toggle("d-none");
            };

            renderDropdown();


            const aantalDagenInput = document.getElementById("aantalDagenInput");
            const verkorteCheckboxen =
                document.querySelectorAll(".verkorte-vak input");

            function updateVerkorteVakjes() {

                const aantalDagen = parseInt(aantalDagenInput.value);

                verkorteCheckboxen.forEach(cb => {
                    const dag = parseInt(cb.dataset.dag);
                    const wrapper = cb.closest(".verkorte-vak");

                    if (!aantalDagen || dag >= aantalDagen) {
                        // ❌ mag niet → verbergen + deselecteren
                        cb.checked = false;
                        wrapper.style.display = "none";
                    } else {
                        // ✅ mag wel → tonen
                        wrapper.style.display = "inline-flex";
                    }
                });
            }

            // Reageer op wijzigen van aantal dagen
            aantalDagenInput.addEventListener("input", updateVerkorteVakjes);

            // Initiale state bij laden pagina
            updateVerkorteVakjes();

        });
    </script>
}