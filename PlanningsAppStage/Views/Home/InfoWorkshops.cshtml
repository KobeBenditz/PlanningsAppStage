@model List<PlanningsAppStage.Models.WorkshopInfo>

@{
    ViewData["Title"] = "Info workshops";
}

<!-- ========================================= -->
<!-- BOVENSTE DEEL: WORKSHOP TOEVOEGEN -->
<!-- ========================================= -->

<h2>Workshop toevoegen</h2>

<form method="post">
    <div class="row mb-3 align-items-end">

        <!-- Titel -->
        <div class="col-md-4">
            <label class="form-label">Titel</label>
            <input type="text" class="form-control" name="Titel" />
        </div>

        <!-- Soort -->
        <div class="col-md-2">
            <label class="form-label">Soort</label>

            <div class="position-relative soort-wrapper">
                <div class="form-control soortSelect" style="cursor:pointer;">
                    <span class="soortGeselecteerd">-- kies --</span>
                </div>

                <div class="border bg-white d-none position-absolute w-100 mt-1 soortDropdown"
                     style="z-index:1000;">
                    @foreach (string soort in ViewBag.Soorten)
                    {
                        <div class="soort-optie d-flex justify-content-between align-items-center"
                             data-value="@soort">
                            <span>@soort</span>
                            <button type="button"
                                    class="btn btn-sm btn-link text-danger verwijder-soort"
                                    data-naam="@soort">
                                ✕
                            </button>
                        </div>
                    }

                    <div class="border-top mt-1 pt-1 text-center">
                        <button type="button"
                                class="btn btn-sm btn-outline-success voeg-soort-toe">
                            + soort toevoegen
                        </button>
                    </div>
                </div>

                <input type="hidden" name="Soort" class="soortValue" />
            </div>
        </div>

        <!-- Aantal beschikbaar -->
        <div class="col-md-1">
            <label class="form-label">Aantal beschikbaar</label>
            <input type="number" class="form-control" name="AantalBeschikbaar" min="0" />
        </div>

        <!-- Aantal dagen -->
        <div class="col-md-1">
            <label class="form-label">Aantal dagen</label>
            <input type="number"
                   class="form-control"
                   name="AantalDagen"
                   id="aantalDagenInput"
                   min="1" />
        </div>

        <!-- Verkorte versie -->
        <div class="row-md-3">
            <label class="form-label d-block">Verkorte versie mogelijk</label>

            <div class="verkorte-container">
                @for (int i = 1; i <= 10; i++)
                {
                    <label class="verkorte-vak">
                        <input type="checkbox"
                               name="VerkorteDagen"
                               value="@i"
                               data-dag="@i" />
                        <span>@i</span>
                    </label>
                }
            </div>
        </div>

    </div>

    <button type="submit" class="btn btn-success">Toevoegen</button>
</form>

<hr />

<!-- ========================================= -->
<!-- TABEL: OVERZICHT WORKSHOPS -->
<!-- ========================================= -->

<h2>Overzicht workshops</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>
                Titel
                <span class="th-buttons">
                    <button class="sort-btn">▲</button>
                    <button class="filter-btn">🔍</button>
                </span>
            </th>
            <th>
                Soort
                <span class="th-buttons">
                    <button class="sort-btn">▲</button>
                    <button class="filter-btn">🔍</button>
                </span>
            </th>
            <th>
                Aantal dagen
                <span class="th-buttons">
                    <button class="sort-btn">▲</button>
                    <button class="filter-btn">🔍</button>
                </span>
            </th>
            <th>
                Aantal beschikbaar
                <span class="th-buttons">
                    <button class="sort-btn">▲</button>
                    <button class="filter-btn">🔍</button>
                </span>
            </th>
            <th style="width:40px;"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var workshop in Model)
        {
            <tr>
                <td>@workshop.Titel</td>
                <td>@workshop.Soort</td>
                <td>@workshop.AantalDagen</td>
                <td>@workshop.AantalBeschikbaar</td>
                <td class="text-center">
                    <button type="button"
                            class="btn btn-sm btn-outline-secondary"
                            data-bs-toggle="modal"
                            data-bs-target="#infoWorkshopModal"
                            data-titel="@workshop.Titel"
                            data-soort="@workshop.Soort"
                            data-dagen="@workshop.AantalDagen"
                            data-beschikbaar="@workshop.AantalBeschikbaar"
                            data-verkort='@System.Text.Json.JsonSerializer.Serialize(workshop.VerkorteDagen)'>
                        ℹ
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- ========================================= -->
<!-- MODAL: INFO WORKSHOP -->
<!-- ========================================= -->

<div class="modal fade" id="infoWorkshopModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="iwTitel"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p><strong>Soort:</strong> <span id="iwSoort"></span></p>
                <p><strong>Aantal dagen:</strong> <span id="iwDagen"></span></p>
                <p><strong>Aantal beschikbaar:</strong> <span id="iwBeschikbaar"></span></p>
                <p>
                    <strong>Verkorte versies:</strong>
                    <span id="iwVerkort"></span>
                </p>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // =============================
            // Verkorte dagen (formulier)
            // =============================
            const aantalDagenInput = document.getElementById("aantalDagenInput");
            const verkorteCheckboxen = document.querySelectorAll(".verkorte-vak input");

            function updateVerkorteVakjes() {
                if (!aantalDagenInput) return;

                const aantalDagen = parseInt(aantalDagenInput.value);

                verkorteCheckboxen.forEach(cb => {
                    const dag = parseInt(cb.dataset.dag);
                    const wrapper = cb.closest(".verkorte-vak");

                    if (!aantalDagen || dag >= aantalDagen) {
                        cb.checked = false;
                        wrapper.style.display = "none";
                    } else {
                        wrapper.style.display = "inline-flex";
                    }
                });
            }

            if (aantalDagenInput) {
                aantalDagenInput.addEventListener("input", updateVerkorteVakjes);
                updateVerkorteVakjes();
            }

            // =============================
            // Modal info vullen
            // =============================
            const modal = document.getElementById("infoWorkshopModal");

            modal.addEventListener("show.bs.modal", function (event) {
                const button = event.relatedTarget;

                document.getElementById("iwTitel").textContent = button.dataset.titel;
                document.getElementById("iwSoort").textContent = button.dataset.soort;
                document.getElementById("iwDagen").textContent = button.dataset.dagen;
                document.getElementById("iwBeschikbaar").textContent = button.dataset.beschikbaar;

                const verkorte = JSON.parse(button.dataset.verkort || "[]");
                const tekst = document.getElementById("iwVerkort");
                tekst.textContent = "";

                if (verkorte.length === 0) {
                    tekst.textContent = "Geen";
                    return;
                }

                verkorte.sort((a, b) => a - b);

                const lijstTekst =
                    verkorte.length === 1
                        ? verkorte[0]
                        : verkorte.slice(0, -1).join(", ") + " en " + verkorte.at(-1);

                // ✅ “dag” alleen als het getal echt 1 is
                const suffix =
                    (verkorte.length === 1 && verkorte[0] === 1)
                        ? "dag"
                        : "dagen";

                tekst.textContent = `${lijstTekst} ${suffix}`;
            });

        });
    </script>
}