@model List<PlanningsAppStage.Models.WorkshopInfo>

@{
    // Titel van de pagina
    ViewData["Title"] = "Info workshops";
}

<!-- ========================================= -->
<!-- BOVENSTE DEEL: WORKSHOP TOEVOEGEN -->
<!-- ========================================= -->
<!--
    Dit formulier is voorlopig alleen visueel.
    Alle velden zijn invulbaar, maar doen nog niets.
-->

<h2>Workshop toevoegen</h2>

<form method="post">
    <div class="row mb-3 align-items-end">

        <!-- Titel -->
        <div class="col-md-4">
            <label class="form-label">Titel</label>
            <input type="text"
                   class="form-control"
                   name="Titel" />
        </div>

        <!-- Soort -->
        <div class="col-md-2">
            <label class="form-label">Soort</label>

            <div class="position-relative soort-wrapper">

                <!-- Fake select -->
                <div class="form-control soortSelect" style="cursor:pointer;">
                    <span class="soortGeselecteerd">-- kies --</span>
                </div>

                <!-- Dropdown -->
                <div class="border bg-white d-none position-absolute w-100 mt-1 soortDropdown"
                     style="z-index:1000;">
                    @foreach (string soort in ViewBag.Soorten)
                    {
                        <div class="soort-optie d-flex justify-content-between align-items-center"
                             data-value="@soort">
                            <span>@soort</span>
                            <button type="button"
                                    class="btn btn-sm btn-link text-danger verwijder-soort"
                                    data-naam="@soort">
                                ✕
                            </button>
                        </div>
                    }

                    <div class="border-top mt-1 pt-1 text-center">
                        <button type="button"
                                class="btn btn-sm btn-outline-success voeg-soort-toe">
                            + soort toevoegen
                        </button>
                    </div>
                </div>

                <!-- Hidden waarde -->
                <input type="hidden" name="Soort" class="soortValue" />
            </div>

        </div>
        <!-- Aantal beschikbaar (kort input, volledig label) -->
        <div class="col-md-1">
            <label class="form-label">Aantal beschikbaar</label>
            <input type="number"
                   class="form-control"
                   name="AantalBeschikbaar"
                   min="0" />
        </div>

        <!-- Aantal dagen (kort input, volledig label) -->
        <div class="col-md-1">
            <label class="form-label">Aantal dagen</label>
            <input type="number"
                   class="form-control"
                   name="AantalDagen"
                   id="aantalDagenInput"
                   min="1" />
        </div>

        

        <!-- Verkorte versie -->
        
        <div class="row-md-3">
            <label class="form-label d-block">Verkorte versie mogelijk</label>

            <div class="verkorte-container">
                @for (int i = 1; i <= 10; i++)
                {
                    <label class="verkorte-vak">
                        <input type="checkbox"
                               name="VerkorteDagen"
                               value="@i"
                               data-dag="@i" />
                        <span>@i</span>
                    </label>
                }
            </div>
        </div>


    </div>

    <button type="submit" class="btn btn-success">
        Toevoegen
    </button>
</form>


<hr />

<!-- ========================================= -->
<!-- TABEL: OVERZICHT WORKSHOPS -->
<!-- ========================================= -->

<h2>Overzicht workshops</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th data-column="Titel">
                Titel
                <span class="th-buttons">
                    <button class="sort-btn" title="Sorteren">▲</button>
                    <button class="filter-btn" title="Filteren">🔍</button>
                </span>
            </th>
            <th data-column="Soort">
                Soort
                <span class="th-buttons">
                    <button class="sort-btn" title="Sorteren">▲</button>
                    <button class="filter-btn" title="Filteren">🔍</button>
                </span>
            </th>
            <th data-column="Aantal dagen">
                Aantal dagen
                <span class="th-buttons">
                    <button class="sort-btn" title="Sorteren">▲</button>
                    <button class="filter-btn" title="Filteren">🔍</button>
                </span>
            </th>
            <th data-column="Aantal beschikbaar">
                Aantal beschikbaar
                <span class="th-buttons">
                    <button class="sort-btn" title="Sorteren">▲</button>
                    <button class="filter-btn" title="Filteren">🔍</button>
                </span>
            </th>
        </tr>
    </thead>
    <tbody>

        @*
            We lopen door alle workshops uit de controller
            Elke workshop wordt één rij in de tabel
        *@
        @foreach (var workshop in Model)
        {
            <tr>
                <td>@workshop.Titel</td>
                <td>@workshop.Soort</td>
                <td>@workshop.AantalDagen</td>
                <td>@workshop.AantalBeschikbaar</td>
            </tr>
        }

    </tbody>
</table>
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const aantalDagenInput = document.getElementById("aantalDagenInput");
            const verkorteCheckboxen =
                document.querySelectorAll(".verkorte-vak input");

            function updateVerkorteVakjes() {
                if (!aantalDagenInput) return;

                const aantalDagen = parseInt(aantalDagenInput.value);

                verkorteCheckboxen.forEach(cb => {
                    const dag = parseInt(cb.dataset.dag);
                    const wrapper = cb.closest(".verkorte-vak");

                    if (!aantalDagen || dag >= aantalDagen) {
                        cb.checked = false;
                        wrapper.style.display = "none";
                    } else {
                        wrapper.style.display = "inline-flex";
                    }
                });
            }

            if (aantalDagenInput) {
                aantalDagenInput.addEventListener("input", updateVerkorteVakjes);
                updateVerkorteVakjes();
            }

        });
    </script>
}