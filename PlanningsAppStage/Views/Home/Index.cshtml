@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center mt-5">
    <div class="card mx-auto" style="max-width:900px;">
        <div class="card-body">
            <h1 class="card-title display-5">Welkom bij PlanningsAppStage</h1>
            <p class="lead">Dit is een tijdelijke startpagina. Gebruik de knoppen in de header om door de applicatie te navigeren.</p>
            <p>Voorlopige links:</p>
            <div class="d-flex justify-content-center gap-2">
                <a class="btn btn-outline-primary" asp-controller="Home" asp-action="OverzichtPlanning">Overzicht planning</a>
                <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="InfoMedewerkers">Info medewerkers</a>
            </div>
            <hr />
            <p class="text-muted small">Deze pagina is tijdelijk — inhoud wordt later aangevuld.</p>
        </div>
    </div>
</div>
