@model List<PlanningsAppStage.Models.Workshop>

@{
    // Titel van de pagina
    // Deze titel wordt ook gebruikt in de <title> van de layout
    ViewData["Title"] = "Overzicht planning";
}


<!-- ========================================= -->
<!-- BOVENSTE DEEL: WORKSHOP TOEVOEGEN -->
<!-- ========================================= -->
<!--
    Dit formulier is voorlopig alleen visueel.
    Alle velden zijn invulbaar, maar:
    - de knop doet nog niets
    - de ingevulde data wordt nergens opgeslagen
-->


<h2>Planning aanpassen</h2>
<form method="post">

    <!-- ========================= -->
    <!-- BASISGEGEVENS WORKSHOP -->
    <!-- ========================= -->
    <div class="row mb-3">

        <!-- WORKSHOP -->
        <div class="col-md-4">
            <label class="form-label">Workshop</label>
            <input type="text"
                   id="workshopZoek"
                   name="workshopTitel"
                   class="form-control"
                   list="workshopLijst"
                   placeholder="Zoek workshop"
                   required />
        </div>

        <!-- AANTAL DAGEN -->
        <div class="col-md-2">
            <label class="form-label">Aantal dagen</label>
            <select id="aantalDagen"
                    class="form-select">
            </select>
        </div>

        <!-- LOCATIE -->
        <div class="col-md-4">
            <label class="form-label">Locatie</label>
            <input type="text"
                   id="locatieZoek"
                   name="locatieNaam"
                   class="form-control"
                   list="locatieLijst"
                   placeholder="Zoek locatie"
                   required />
        </div>
        
        <datalist id="locatieLijst">
            @foreach (var l in ViewBag.Locaties)
            {
                <option value="@l.Naam"
                        data-soorten='@Html.Raw(
                                        System.Text.Json.JsonSerializer.Serialize(l.Soorten)
                                    )'>
                </option>
            }
        </datalist>


    </div>

    <!-- ========================= -->
    <!-- VERBORGEN UREN -->
    <!-- ========================= -->
    <!-- Wordt automatisch ingevuld via JS -->
    
    <div class="col-md-4">
        <label class="form-label">Uren</label>
        <input type="hidden"
               id="urenInput"
               name="uren"
               class="form-control"
               readonly />
    </div>


    <!-- ========================= -->
    <!-- DAGEN -->
    <!-- ========================= -->
    <div id="dagenContainer"></div>

    <button type="submit" class="btn btn-success mt-3">
        Toevoegen
    </button>

</form>

<!-- ========================= -->
<!-- WORKSHOP SUGGESTIES -->
<!-- ========================= -->
<datalist id="workshopLijst">
    @foreach (var w in ViewBag.WorkshopInfos)
    {
        <option value="@w.Titel"
                data-dagen="@w.AantalDagen"
                data-verkort="@w.VerkorteVersie"
                data-soort="@w.Soort">
        </option>
    }
</datalist>





<hr />

<!-- ========================================= -->
<!-- ONDERSTE DEEL: TABEL MET WORKSHOPS -->
<!-- ========================================= -->

<h2>Overzicht workshops</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Datum</th>
            <th>Uren</th>
            <th>Locatie</th>
            <th>Titel</th>
            <th>Lesgever</th>
        </tr>
    </thead>
    <tbody>

        @*
            We overlopen hier de lijst van workshops
            die vanuit de controller werd doorgestuurd.
            Elke workshop wordt één rij in de tabel.
        *@
        @foreach (var workshop in Model)
        {
            <tr>
                <td>@workshop.Datum.ToString("dd/MM/yyyy")</td>
                <td>@workshop.Uren</td>
                <td>@workshop.Locatie</td>
                <td>@workshop.Titel</td>
                <td>@workshop.Lesgever</td>
            </tr>
        }

    </tbody>
</table>
@section Scripts {
    <script>
        /*
        =================================================
        REFERENTIES NAAR ELEMENTEN
        =================================================
        */
        const workshopInput = document.getElementById("workshopZoek");
        const aantalDagenSelect = document.getElementById("aantalDagen");
        const dagenContainer = document.getElementById("dagenContainer");
        const locatieInput = document.getElementById("locatieZoek");
        const urenInput = document.getElementById("urenInput");

        /*
        =================================================
        WORKSHOP GEKOZEN
        - Aantal dagen invullen
        - Verkorte opties toevoegen
        - Dag-lijnen genereren
        =================================================
        */
        workshopInput.addEventListener("change", function () {

            // Zoek de juiste option in de datalist
            const optie = [...document.querySelectorAll("#workshopLijst option")]
                .find(o => o.value === this.value);

            if (!optie) return;

            const standaardDagen = optie.dataset.dagen;
            const verkorteVersie = optie.dataset.verkort;

            // Dropdown leegmaken
            aantalDagenSelect.innerHTML = "";

            // Standaard aantal dagen toevoegen
            voegAantalToe(standaardDagen);

            // Verkorte versie bv "1-2-3"
            if (verkorteVersie) {
                verkorteVersie.split("-").forEach(v => voegAantalToe(v));
            }

            // Standaardwaarde selecteren
            aantalDagenSelect.value = standaardDagen;

            // Dagen genereren
            genereerDagen(standaardDagen);
        });

        // Hulpfunctie om geen duplicaten te krijgen
        function voegAantalToe(value) {
            if ([...aantalDagenSelect.options].some(o => o.value === value)) return;

            const opt = document.createElement("option");
            opt.value = value;
            opt.text = value;
            aantalDagenSelect.appendChild(opt);
        }

        // Bij wijziging aantal dagen opnieuw lijnen maken
        aantalDagenSelect.addEventListener("change", function () {
            genereerDagen(this.value);
        });

        /*
        =================================================
        DAGEN GENEREREN
        - Per dag: datum, lesgever, code
        =================================================
        */
        function genereerDagen(aantal) {

            // Container leegmaken
            dagenContainer.innerHTML = "";

            for (let i = 0; i < aantal; i++) {

                dagenContainer.innerHTML += `
                    <div>
                        <input type="date" name="Datum[]" required />
                        <input type="text" name="Lesgever[]" placeholder="Lesgever" />
                        <input type="text" placeholder="Code" required />
                    </div>
                `;
            }
        }

        /*
        =================================================
        LOCATIE GEKOZEN (DATALIST)
        - Automatisch uren bepalen
        =================================================
        */
        locatieInput.addEventListener("input", function () {

            // Zoek bijhorende option in de datalist
            const optie = [...document.querySelectorAll("#locatieLijst option")]
                .find(o => o.value === this.value);

            // Ongeldige locatie → uren leegmaken
            if (!optie) {
                urenInput.value = "";
                return;
            }

            // Soorten uitlezen
            const soorten = JSON.parse(optie.dataset.soorten || "[]");

            // Simpel gehouden: eerste soort nemen
            if (soorten.length > 0) {
                urenInput.value =
                    soorten[0].StartUur + " - " + soorten[0].EindUur;
            }
        });
    </script>
}

